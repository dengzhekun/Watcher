<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="watcher_database" />
        <exclude domain="database" path="watcher_database-wal" />
        <exclude domain="database" path="watcher_database-shm" />
        <exclude domain="sharedpref" path="llm_wallet_prefs.xml" />
        <exclude domain="sharedpref" path="llm_wallet_secrets.xml" />
        <exclude domain="file" path="agentframework/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="watcher_database" />
        <exclude domain="database" path="watcher_database-wal" />
        <exclude domain="database" path="watcher_database-shm" />
        <exclude domain="sharedpref" path="llm_wallet_prefs.xml" />
        <exclude domain="sharedpref" path="llm_wallet_secrets.xml" />
        <exclude domain="file" path="agentframework/" />
    </device-transfer>
</data-extraction-rules>
