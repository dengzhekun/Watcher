<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Speech recognition permission -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Storage permission for saved snapshots on old Android versions -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:name="com.example.watcher.WatcherApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Watcher"
        tools:targetApi="31">
        <uses-native-library android:name="libOpenCL.so" android:required="false" />
        <uses-native-library android:name="libvndksupport.so" android:required="false" />

        <activity
            android:name="com.example.watcher.LiteRtActivity"
            android:exported="false"
            android:theme="@style/Theme.Watcher" />
        <activity
            android:name="com.example.watcher.AgentConfigActivity"
            android:exported="false"
            android:theme="@style/Theme.Watcher" />
        <activity
            android:name="com.example.watcher.ApiWalletActivity"
            android:exported="true"
            android:theme="@style/Theme.Watcher">
            <intent-filter>
                <action android:name="com.xmax.watcher.action.OPEN_WALLET" />
                <action android:name="com.example.watcher.action.OPEN_WALLET" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.example.watcher.WatcherImportActivity"
            android:exported="true"
            android:theme="@style/Theme.Watcher" />
        <activity
            android:name="com.example.watcher.DigitalLifeCardActivity"
            android:exported="false"
            android:theme="@style/Theme.Watcher" />
        <activity
            android:name="com.example.watcher.MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize"
            android:label="@string/app_name"
            android:theme="@style/Theme.Watcher">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
